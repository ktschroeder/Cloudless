	<ItemGroup>
		<ProjectReference Include="..\Cloudless.PluginBase\Cloudless.PluginBase.csproj">
			<Private>false</Private>
			<ExcludeAssets>runtime</ExcludeAssets>
		</ProjectReference>
	</ItemGroup>

</Project>
