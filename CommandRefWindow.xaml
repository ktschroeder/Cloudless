<Window x:Class="Cloudless.CommandRefWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey Reference"
        Height="425"
        Width="830"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown"
        AllowsTransparency="True">

    <Border Background="#FAFAFA"
            CornerRadius="6"
            Padding="0">


        <DockPanel>

            <!-- Header -->
            <Border Background="#F0F0F0"
                    Padding="8"
                    DockPanel.Dock="Top"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Command Palette Reference"
                           FontWeight="SemiBold"
                           Foreground="#333"/>
            </Border>

            <!-- Content with ScrollViewer -->
            <StackPanel Margin="12">
                <StackPanel>

                    <!-- Hotkey List -->
                    <StackPanel Margin="0,0,0,0" Height="340">
                        <TabControl Background="Transparent" BorderThickness="0">

                            <!-- Non-Command -->
                            <TabItem Header="Non-Command">
                                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,10">The command palette provides advanced features using a text-based interface.</TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="':' or ';'" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Open command palette"/>

                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="(palette) Enter" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="Submit command"/>

                                            <TextBlock Grid.Column="0" Grid.Row="2" Text="(palette) Esc" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="2" Text="Cancel/exit the command palette"/>

                                            <TextBlock Grid.Column="0" Grid.Row="3" Text="(palette) Up and Down" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="3" Text="Traverse through history of commands in the current window"/>

                                            <TextBlock Grid.Column="0" Grid.Row="4" Text="Ctrl ';'" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="4" Text="Execute the most recent valid command"/>

                                            <TextBlock Grid.Column="0" Grid.Row="5" Text="Ctrl [1 through 8]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="5" Text="Run custom commands stored at the respective index"/>

                                            <TextBlock Grid.Column="0" Grid.Row="6" Text="(palette) Tab" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="6" Text="For workspace commands (e.g. 'ws l [name]'), autocomplete workstation name, or cycle through matches."/>

                                            <TextBlock Grid.Column="0" Grid.Row="7" Text="(palette) Shift Tab" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="7" Text="Similar to above, but cycle in the reverse direction."/>

                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- General -->
                            <TabItem Header="General">
                                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="cip" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Copy image path to clipboard"/>

                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="rev" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="Reveal current image in File Explorer"/>

                                            <TextBlock Grid.Column="0" Grid.Row="2" Text="c all" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="2" Text="Close all open instances of Cloudless"/>

                                            <TextBlock Grid.Column="0" Grid.Row="3" Text="c others" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="3" Text="Close all windows except this one"/>

                                            <TextBlock Grid.Column="0" Grid.Row="4" Text="help" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="4" Text="Open hotkey reference window"/>

                                            <TextBlock Grid.Column="0" Grid.Row="5" Text="m all / others" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="5" Text="Minimize all windows, or all other windows"/>

                                            <TextBlock Grid.Column="0" Grid.Row="6" Text="um all" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="6" Text="Unminimize all windows"/>

                                            <TextBlock Grid.Column="0" Grid.Row="7" Text="c[Int 1-8] set [String]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="7" Text="Save custom command [String] at index [Int]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="8" Text="c[Int 1-8] view" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="8" Text="View command stored at index [Int]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="9" Text="c[Int 1-8] run" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="9" Text="Run command stored at index [Int]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="10" Text="ris" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="10" Text="Perform an online reverse-image-search for the current image, including uploading it to a temporary host."/>

                                            <TextBlock Grid.Column="0" Grid.Row="11" Text="ris [service]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="11" Text="See above. [service] can be google, bing, yandex, tineye, or saucenao. Their first letters can also be used."/>

                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- VIEW -->
                            <TabItem Header="View">
                                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>


                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="dm [mode]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Set display mode: stretch/zoom/best/bestnozoom. Numbers 1-4 can also be used."/>

                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="dim [Int] [Int]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="Set window dimensions to [Int]x[Int]"/>

                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Image -->
                            <TabItem Header="Image">
                                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="[Int]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Jump to the image with index [Int] in the current directory"/>

                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="+[Int]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="Jump [Int] images forward in directory"/>

                                            <TextBlock Grid.Column="0" Grid.Row="2" Text="-[Int]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="2" Text="Jump [int] images backward in directory"/>

                                            <TextBlock Grid.Column="0" Grid.Row="3" Text="p" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="3" Text="Open most recently loaded image"/>

                                            <TextBlock Grid.Column="0" Grid.Row="4" Text="first | last" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="4" Text="Open first or last image in current directory"/>

                                            <TextBlock Grid.Column="0" Grid.Row="5" Text="/[query]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="5" Text="Open the next image in current directory whose filename contains [query], case insensitive. Wraps around at end."/>

                                            <TextBlock Grid.Column="0" Grid.Row="6" Text="sort [type] [order]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="6" Text="Set directory sort order. Type can be 'name' or 'date'. Order can be 'asc' or 'desc'."/>

                                            <TextBlock Grid.Column="0" Grid.Row="7" Text="o [path]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="7" Text="Open the image at [path], which may be relative or absolute. Or open all images in directory (max 10)"/>

                                            <TextBlock Grid.Column="0" Grid.Row="8" Text="o! [path]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="8" Text="Open the image at [path], which may be relative or absolute. Or open all images in directory (ignore max)"/>

                                            <TextBlock Grid.Column="0" Grid.Row="9" Text="rec [Int]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="9" Text="Open the [Int] most recent images, in new windows"/>

                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- WINDOWS -->
                            <TabItem Header="Workspace">
                                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,10">A "workspace" is the collective arrangement of all open Cloudless windows. When you save a workspace, you can later<LineBreak /> load it to quickly open all its images, with their identical position, zoom, pan, crop, and Z-order. (Tip: combine this with<LineBreak />custom commands to rapidly page through your custom image arrangements.)</TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Column="0" Grid.Row="0" Text="ws save | s [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="0" Text="Save current workspace to storage as [name]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="1" Text="ws save! | s! [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="1" Text="Save/overwrite current workspace to storage as [name]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="2" Text="ws load | l [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="2" Text="Load workspace [name] and close all currently open Cloudless windows"/>

                                            <TextBlock Grid.Column="0" Grid.Row="3" Text="ws merge | m [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="3" Text="Merge workspace [name] (load it without closing any windows)"/>

                                            <TextBlock Grid.Column="0" Grid.Row="4" Text="ws rev" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="4" Text="In File Explorer, reveal directory of workspace (.cloudless) files"/>

                                            <TextBlock Grid.Column="0" Grid.Row="5" Text="qs" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="5" Text="Quicksave: Save current workspace to an unnamed workspace, which can be quickloaded. This always overwrites."/>

                                            <TextBlock Grid.Column="0" Grid.Row="6" Text="qs c" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="6" Text="Quicksave (see above), and then close all windows if successful"/>

                                            <TextBlock Grid.Column="0" Grid.Row="7" Text="ql" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="7" Text="Quickload: load the quicksave workspace"/>

                                            <TextBlock Grid.Column="0" Grid.Row="8" Text="qm" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="8" Text="Quickmerge: merge the quicksave workspace (load it without closing any windows)"/>

                                            <TextBlock Grid.Column="0" Grid.Row="9" Text="ws preview | p [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="9" Text="Open gallery view of workspace preview"/>

                                            <TextBlock Grid.Column="0" Grid.Row="10" Text="ws rename | r [old] [new]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="10" Text="Rename workspace [old] to [new]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="11" Text="ws delete [name]" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="11" Text="Delete workspace [name]"/>

                                            <TextBlock Grid.Column="0" Grid.Row="12" Text="ws origin" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Grid.Row="12" Text="Reveal the workspace's name from which this window's current image originated, if any"/>

                                        </Grid>
                                        <TextBlock Margin="0,10,0,1">With "ws l", "ws s", etc., press tab to autocomplete name (press repeatedly to traverse matches. Hold Shift to reverse direction)</TextBlock>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            

                        </TabControl>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Close"
                                Style="{StaticResource CloudlessPrimaryButton}"
                                Click="Close_Click"
                                FontWeight="SemiBold"
                                Width="60"/>
                    </StackPanel>

                </StackPanel>
            </StackPanel>

        </DockPanel>
    </Border>
</Window>
