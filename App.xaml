<Application x:Class="Cloudless.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Cloudless"
             xmlns:controls="clr-namespace:Cloudless.Controls"
            >
    <Application.Resources>

        <!-- Theme resources (light defaults) -->
        <Color x:Key="WindowBackgroundColor">#FFF9F9F9</Color>
        <Color x:Key="SecondaryBackgroundColor">#FFF0F0F0</Color>
        <Color x:Key="PrimaryForegroundColor">#FF222222</Color>
        <Color x:Key="SecondaryForegroundColor">#FF555555</Color>
        <Color x:Key="ButtonBackgroundColor">#FFEDEDED</Color>
        <Color x:Key="ButtonBorderColor">#FFD0D0D0</Color>
        <Color x:Key="PrimaryButtonBackgroundColor">#FFDDE6F3</Color>
        <Color x:Key="PrimaryButtonBorderColor">#FFB5C7E3</Color>

        <SolidColorBrush x:Key="WindowBackground" Color="{DynamicResource WindowBackgroundColor}" />
        <SolidColorBrush x:Key="SecondaryBackground" Color="{DynamicResource SecondaryBackgroundColor}" />
        <SolidColorBrush x:Key="PrimaryForeground" Color="{DynamicResource PrimaryForegroundColor}" />
        <SolidColorBrush x:Key="SecondaryForeground" Color="{DynamicResource SecondaryForegroundColor}" />
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="{DynamicResource ButtonBackgroundColor}" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="{DynamicResource ButtonBorderColor}" />
        <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="{DynamicResource PrimaryButtonBackgroundColor}" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="{DynamicResource PrimaryButtonBorderColor}" />
        <Color x:Key="ButtonHoverBackgroundColor">#FFE0E0E0</Color>
        <Color x:Key="ButtonPressedBackgroundColor">#FFD6D6D6</Color>
        <Color x:Key="PrimaryButtonHoverBackgroundColor">#FFC9D7F0</Color>
        <Color x:Key="PrimaryButtonPressedBackgroundColor">#FFB7CBE8</Color>

        <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="{DynamicResource ButtonHoverBackgroundColor}" />
        <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="{DynamicResource ButtonPressedBackgroundColor}" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBackgroundBrush" Color="{DynamicResource PrimaryButtonHoverBackgroundColor}" />
        <SolidColorBrush x:Key="PrimaryButtonPressedBackgroundBrush" Color="{DynamicResource PrimaryButtonPressedBackgroundColor}" />
        <!-- Overlay / accent brushes -->
        <SolidColorBrush x:Key="OverlayBackground" Color="#CC000000" />
        <SolidColorBrush x:Key="OverlayForeground" Color="#EAEAEA" />
        <Color x:Key="AccentBorderColor">#66FFFFFF</Color>
        <SolidColorBrush x:Key="AccentBorderBrush" Color="{DynamicResource AccentBorderColor}" />
        <Color x:Key="FadeBaseColor">#FF000000</Color>

        <!-- Converters -->
        <local:WidthMinusConverter x:Key="WidthMinusConverter" />

        <!-- Base button style -->
        <Style x:Key="CloudlessButton"
           TargetType="Button">
            <Setter Property="Padding" Value="140,60"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ContextMenu and MenuItem styling -->
        <Style TargetType="ContextMenu">
            <!-- Use DynamicResource directly inside template to ensure updates when theme changes at runtime -->
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <controls:FullWidthStackPanel />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{DynamicResource SecondaryBackground}"
                                BorderBrush="{DynamicResource PrimaryButtonBorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                                    <!-- Overlay canvas for drawing full-width separators -->
                                    <Grid>
                                        <Canvas x:Name="SeparatorOverlay" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" />
                                        <!-- Use ItemsPresenter directly to avoid an always-visible scrollbar; let Popup sizing handle overflow -->
                                        <ItemsPresenter Margin="-8,0,0,0" SnapsToDevicePixels="True"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <!-- Full-size highlight overlay behind the content; placed before Border so Border content appears above it -->
                            <Border x:Name="HighlightOverlay" Background="{DynamicResource ButtonHoverBackgroundBrush}" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                            <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0" x:Name="Icon" ContentSource="Icon" VerticalAlignment="Center" Margin="0,0,8,0" TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>

                                    <!-- Submenu arrow -->
                                    <Path Grid.Column="2" x:Name="Arrow" Data="M 0 0 L 6 4 L 0 8 Z" Fill="{TemplateBinding Foreground}" Visibility="Collapsed" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Popup for submenus -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource SecondaryBackground}" BorderBrush="{DynamicResource PrimaryButtonBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="2">
                                    <StackPanel IsItemsHost="True" />
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="HighlightOverlay" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Full-width separator rendered as a MenuItem to avoid left inset caused by ItemsPresenter padding -->
        <Style x:Key="ContextMenuFullWidthSeparator" TargetType="MenuItem">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Height="1" Background="{DynamicResource AccentBorderBrush}" HorizontalAlignment="Stretch" Width="Auto" Margin="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{DynamicResource AccentBorderBrush}"
                                HorizontalAlignment="Left"
                                Width="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=ActualWidth, Converter={StaticResource WidthMinusConverter}, ConverterParameter=16}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RepeatButton used inside ScrollBar track where hover should not change the background -->
        <Style x:Key="ScrollRepeatButton" TargetType="RepeatButton" BasedOn="{StaticResource {x:Type RepeatButton}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl global style removed to avoid centering tab content; headers are centered via TabItem/HeaderTemplate instead -->

        <!-- RepeatButton used by ScrollBar (arrow areas) -> make them follow theme -->
        <Style TargetType="RepeatButton">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar template that uses themed RepeatButtons and Thumb -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="LayoutRoot" Width="Auto" Height="Auto" RenderTransformOrigin="0.5,0.5" Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <RepeatButton x:Name="PART_DecreaseButton" Grid.Row="0" Command="ScrollBar.LineUpCommand" Style="{StaticResource {x:Type RepeatButton}}" Padding="2">
                                <Path Data="M 4 8 L 8 4 L 12 8 Z" Fill="{DynamicResource PrimaryForeground}" Width="10" Height="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </RepeatButton>

                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <!-- Use a bare repeat button that does not change color on hover for the track regions -->
                                    <RepeatButton Style="{StaticResource ScrollRepeatButton}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <!-- Let the Track size the thumb (no fixed Height). Provide a min size and stretch to full width so it's easy to hit. -->
                                    <Thumb x:Name="PART_Thumb" Background="{DynamicResource PrimaryForeground}" MinHeight="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButton}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>

                            <RepeatButton x:Name="PART_IncreaseButton" Grid.Row="2" Command="ScrollBar.LineDownCommand" Style="{StaticResource {x:Type RepeatButton}}" Padding="2">
                                <Path Data="M 4 4 L 8 8 L 12 4 Z" Fill="{DynamicResource PrimaryForeground}" Width="10" Height="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </RepeatButton>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="LayoutRoot" Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton (affects ComboBox toggle) -->
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action -->
        <Style x:Key="CloudlessPrimaryButton"
           TargetType="Button"
           BasedOn="{StaticResource CloudlessButton}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryButtonPressedBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Controls styling to respect theme -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ControlForeground}"/>
                        <Setter Property="Padding" Value="6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="2">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <!-- Make the entire closed area a ToggleButton so clicking anywhere opens the dropdown -->
                                <ToggleButton x:Name="ToggleButton"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"
                                              Padding="4,2"
                                              Focusable="False">
                                    <Grid>
                                        <ContentPresenter x:Name="ContentSite"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          Margin="6,0,26,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>
                                        <Border Width="26" HorizontalAlignment="Right" Background="Transparent">
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="{DynamicResource PrimaryForeground}" Stretch="Uniform" Width="10" Height="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </ToggleButton>
                            </Border>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource ControlBackground}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                            </Trigger>
                            <!-- Hover background for the closed dropdown area -->
                            <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem styling for tab headers to follow theme -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="Padding" Value="6,6"/>
            <!-- Increase gap between tabs to avoid visual clipping -->
            <Setter Property="Margin" Value="0,0,0,0"/>
            <!-- Ensure tabs have a minimum width so header text can center visually -->
            <Setter Property="MinWidth" Value="70"/>
            <!-- Ensure tab content is left-aligned while header text remains centered via HeaderTemplate -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="15,15,0,0" Padding="6,3" ClipToBounds="False">
                            <ContentPresenter x:Name="Content" ContentSource="Header" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="6,0,6,0" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryButtonBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="0"/>
                                <!-- Bring selected tab to front so rounded corners are not visually clipped by neighbors -->
                                <Setter Property="Panel.ZIndex" Value="20"/>
                                <!-- Give selected tab an extra right margin so its right corner is not overlapped -->
                                <Setter Property="Margin" Value="0,0,0,0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ensure tab content inside TabControl is left-aligned by default -->
        <Style TargetType="TabControl">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Box" Width="16" Height="16" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2">
                                    <Path x:Name="CheckMark" Data="M2,8 L6,12 L14,4" Stroke="{TemplateBinding Foreground}" StrokeThickness="2" Visibility="Collapsed" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ItemsPanel template that uses FullWidthStackPanel to allow separators to stretch full width -->
        <ItemsPanelTemplate x:Key="FullWidthItemsPanelTemplate">
            <controls:FullWidthStackPanel />
        </ItemsPanelTemplate>

    </Application.Resources>
    
    
</Application>
