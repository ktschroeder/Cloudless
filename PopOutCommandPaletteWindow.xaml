<Window x:Class="Cloudless.PopOutCommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Info"
        SizeToContent="Width"
        Height="115"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        AllowsTransparency="True">

    <Border Background="#FAFAFA"
            CornerRadius="6"
            Padding="0">


        <DockPanel>

            <!-- Header -->
            <Border Background="#F0F0F0"
                    Padding="8"
                    DockPanel.Dock="Top"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Pop-Out Command Palette"
                           FontWeight="SemiBold"
                           Foreground="#333"/>
            </Border>

            <!-- Content -->
            <StackPanel Margin="12">

                <Border x:Name="CommandPalette"
    Background="#CC1E1E1E"
    CornerRadius="4"
    Padding="6"
    HorizontalAlignment="Left"
    VerticalAlignment="Bottom"
    Focusable="True"
    Panel.ZIndex="99999999">

                    <TextBox x:Name="CommandTextBox"
         TextChanged="CommandPalette_TextChanged"
         SelectionChanged="CommandPalette_SelectionChanged"
         Background="Transparent"
         BorderThickness="0"
         Foreground="#EAEAEA"
         FontFamily="Consolas"
         FontSize="14"
         CaretBrush="White"
         MinWidth="160"
         KeyDown="CommandTextBox_KeyDown"
         PreviewKeyDown="CommandPaletteTextBox_PreviewKeyDown"/>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Content="Close"
                            Style="{StaticResource CloudlessPrimaryButton}"
                            Click="Close_Click"
                            FontWeight="SemiBold"
                            Width="60"/>
                </StackPanel>

            </StackPanel>

        </DockPanel>
    </Border>
</Window>
