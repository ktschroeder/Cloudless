<UserControl x:Class="Cloudless.CommandPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="48" d:DesignWidth="400">
    <Border x:Name="Root" Visibility="Visible" Background="#CC1E1E1E" CornerRadius="4" Padding="6" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6">
        <TextBox x:Name="CommandTextBox"
                 TextChanged="CommandTextBox_TextChanged"
                 SelectionChanged="CommandTextBox_SelectionChanged"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="#EAEAEA"
                 FontFamily="Consolas"
                 FontSize="14"
                 CaretBrush="White"
                 MinWidth="160"
                 KeyDown="CommandTextBox_KeyDown"
                 PreviewKeyDown="CommandTextBox_PreviewKeyDown"/>
    </Border>
</UserControl>