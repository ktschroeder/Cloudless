<Window x:Class="Cloudless.MessageHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message History"
        Height="410"
        Width="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown"
        AllowsTransparency="True">

    <Border Background="{DynamicResource WindowBackground}"
            CornerRadius="6"
            Padding="0">


        <DockPanel>

            <!-- Header -->
            <Border Background="{DynamicResource SecondaryBackground}"
                    Padding="8"
                    DockPanel.Dock="Top"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="System Messages"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryForeground}"/>
            </Border>

            <!-- Content -->
            <StackPanel Margin="12">

                <TextBlock Text="Messages:"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryForeground}"
                           Margin="0,0,0,8"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                    <ListBox x:Name="MessageListBox" KeyDown="MessageListBox_KeyDown"
                             Background="{DynamicResource TextBoxBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                             Padding="4" />
                </ScrollViewer>

                <!-- Close Button -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Content="Close"
                            Style="{StaticResource CloudlessPrimaryButton}"
                            Click="Close_Click"
                            FontWeight="SemiBold"
                            Width="60"/>
                </StackPanel>

            </StackPanel>

        </DockPanel>
    </Border>
</Window>
