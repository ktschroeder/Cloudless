<Window x:Class="Cloudless.WorkspaceLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Workspace"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="600"
        Height="300"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
		Closing="On_Close">
    <Grid Background="#1E1E1E" Opacity="0.95">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
            <TextBlock Text="Workspace Loading..."
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,40" />
            
            <ProgressBar Height="8"
                         Foreground="#007ACC"
                         IsIndeterminate="True"
                         Margin="0,0,0,30" />
            
            <TextBlock x:Name="DetailMessage"
                       Foreground="#B0B0B0"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
