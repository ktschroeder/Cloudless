<UserControl x:Class="Cloudless.FilmStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="150" d:DesignWidth="800">
    <Border Background="#CC000000" Padding="6" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Dragger area -->
            <Grid Grid.Row="0" Background="#00111111">
                <Rectangle Height="4" Fill="Transparent" Cursor="SizeNS" />
            </Grid>

            <!-- Main film strip -->
            <DockPanel Grid.Row="1">
                <ScrollViewer x:Name="PART_ScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                    <StackPanel x:Name="PART_Panel" Orientation="Horizontal" />
                </ScrollViewer>

                <StackPanel DockPanel.Dock="Right" Orientation="Vertical" Margin="8" VerticalAlignment="Top">
                    <CheckBox x:Name="PART_CloseAfterSelect" Content="Close film strip afterward" Foreground="White" Background="Transparent" Margin="0,0,0,4" />
                    <CheckBox x:Name="PART_OpenInNewWindow" Content="Open image in new window" Foreground="White" Background="Transparent" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>